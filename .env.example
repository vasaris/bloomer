# ── Обязательное ───────────────────────────────────────────────
BOT_TOKEN=put-your-telegram-bot-token-here

# Whitelist чат-id, через запятую. Сейчас: Иван (+ Лена позже).
# Узнать свой id: напиши боту @userinfobot или см. /start в логах.
OWNER_CHAT_IDS=123456789

# ── Окружение ──────────────────────────────────────────────────
TIMEZONE=Europe/Belgrade
DB_PATH=blumer.db

# ── Локация для проверки жары (погодное API, Sprint 6) ─────────
# По умолчанию Нови-Сад. Open-Meteo — без ключа.
LATITUDE=45.2671
LONGITUDE=19.8335

# ── Расписание пушей (HH:MM, 24ч, локальная TZ) ────────────────
# Дефолты из спеки. Подставь свой реальный ритм (подъём/работа/вечер).
PUSH_MORNING_BRIEF=07:30
PUSH_WALK_MORNING=08:00
PUSH_NOSE_TASK=13:00
PUSH_WALK_EVENING=19:00
PUSH_ASTHMA_CHECK=20:00
PUSH_DAY_SUMMARY=21:30
PUSH_WEEKLY_REVIEW=20:00
PUSH_WEEKLY_REVIEW_DOW=sun

# ── Тихие часы (пуши не приходят) ──────────────────────────────
QUIET_HOURS_START=22:00
QUIET_HOURS_END=07:00

# ── Sprint 8: Бэкапы БД ────────────────────────────────────────
# Время ежедневного бэкапа (HH:MM, локальная TZ). off/none — отключить.
BACKUP_TIME=03:30
# Сколько последних бэкапов хранить (ротация). 0 — не чистить.
BACKUP_KEEP=7
# Куда складывать. Пусто = подкаталог backups/ рядом с БД (на том же Volume).
# BACKUP_DIR=/data/backups
# Слать офсайт-копию .db в Telegram (тихо) при авто-бэкапе. on/off.
BACKUP_TO_TELEGRAM=on

# ── Sprint 7: Claude API (диалог /ask) ─────────────────────────
# Ключ из console.anthropic.com. Без него команды работают, /ask вежливо подскажет.
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
